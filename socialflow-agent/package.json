{
  "name": "socialflow-agent",
  "version": "1.0.0",
  "description": "SocialFlow Local Agent - Browser automation & Video processing",
  "main": "electron/main.js",
  "bin": {
    "socialflow": "./cli.js"
  },
  "scripts": {
    "start": "node agent.js",
    "dev": "node --watch agent.js",
    "setup": "node setup.js",
    "launch": "node launcher.js",
    "electron": "electron .",
    "electron:dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.socialflow.agent",
    "productName": "SocialFlow Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!debug/**",
      "!.env",
      "!nul"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.png"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.712.0",
    "@aws-sdk/s3-request-presigner": "^3.1008.0",
    "@supabase/supabase-js": "^2.49.1",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "fluent-ffmpeg": "^2.1.3",
    "https-proxy-agent": "^7.0.6",
    "open": "^10.1.0",
    "openai": "^4.77.0",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
